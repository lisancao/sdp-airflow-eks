# Terraform
*.tfstate
*.tfstate.*
*.tfvars
!terraform/example.tfvars
.terraform/
.terraform.lock.hcl
crash.log

# Credentials — never commit generated user tokens or keys
credentials*
# Local values with account-specific ARNs (kept out of the public repo)
k8s/*.local.yaml
*.pem
kubeconfig*

# Python
__pycache__/
*.pyc
.venv/

# Editor
.idea/
.vscode/
*.swp
